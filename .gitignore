# Secrets & environment
.env
.env.local
.env.*.local
.env.development
.env.production
!.env.example

# Astro build output
dist/
.astro/

# Dependencies
node_modules/
.pnpm-store/

# Cloudflare / Wrangler
.wrangler/
worker/.wrangler/
worker/node_modules/
worker/dist/

# Pagefind generated index (regenerated every build)
public/pagefind/

# Build-time generated content indexes (produced by scripts/extract-*.ts)
src/content/generated/items.json
src/content/generated/vocabulary.json
src/content/generated/search-documents.json

# Hand-curated AI fallback examples are committed (not generated each build)
!src/content/generated/synthetic-examples.json

# Working scratch files from missing-examples scripts
scripts/.*.tsv

# IDE / editor
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript build info
*.tsbuildinfo

# Testing / coverage
coverage/
.nyc_output/
