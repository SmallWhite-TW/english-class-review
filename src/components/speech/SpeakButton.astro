---
interface Props {
  text: string;
  lang?: 'en-US' | 'en-GB' | 'zh-TW' | 'zh-CN';
  size?: 'sm' | 'md';
  label?: string;
}

const { text, lang = 'en-US', size = 'sm', label } = Astro.props;
---

<button
  type="button"
  class:list={['speak-btn', `speak-btn--${size}`]}
  data-speak-text={text}
  data-speak-lang={lang}
  aria-label={label ?? `播放：${text}`}
  aria-pressed="false"
  title={`播放發音：${text}`}
>
  <svg
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
    <path class="wave wave-1" d="M15.54 8.46a5 5 0 0 1 0 7.07" />
    <path class="wave wave-2" d="M19.07 4.93a10 10 0 0 1 0 14.14" />
  </svg>
</button>

<style>
  .speak-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--neon-cyan, #00ffff);
    background: transparent;
    color: var(--neon-cyan, #00ffff);
    cursor: pointer;
    padding: 0;
    border-radius: 4px;
    transition:
      box-shadow 0.15s ease,
      transform 0.15s ease,
      color 0.15s ease,
      background 0.15s ease;
    clip-path: polygon(0 0, calc(100% - 4px) 0, 100% 4px, 100% 100%, 4px 100%, 0 calc(100% - 4px));
  }
  .speak-btn--sm {
    width: 1.5rem;
    height: 1.5rem;
  }
  .speak-btn--md {
    width: 2rem;
    height: 2rem;
  }
  .speak-btn svg {
    width: 65%;
    height: 65%;
  }
  .speak-btn:hover {
    box-shadow:
      0 0 6px rgba(0, 255, 255, 0.6),
      0 0 14px rgba(0, 255, 255, 0.3);
    background: rgba(0, 255, 255, 0.08);
  }
  .speak-btn:active {
    transform: scale(0.94);
  }
  .speak-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    border-color: #555;
    color: #777;
  }
  .speak-btn.is-playing {
    color: var(--neon-magenta, #ff00aa);
    border-color: var(--neon-magenta, #ff00aa);
    animation: speak-pulse 0.6s ease-out infinite alternate;
  }
  .speak-btn.is-playing .wave-1 {
    animation: wave-fade 0.8s ease-in-out infinite alternate;
  }
  .speak-btn.is-playing .wave-2 {
    animation: wave-fade 0.8s ease-in-out 0.2s infinite alternate;
  }

  @keyframes speak-pulse {
    from {
      box-shadow:
        0 0 5px rgba(255, 0, 170, 0.5),
        0 0 10px rgba(255, 0, 170, 0.3);
    }
    to {
      box-shadow:
        0 0 12px rgba(255, 0, 170, 0.9),
        0 0 22px rgba(255, 0, 170, 0.5),
        0 0 32px rgba(255, 0, 170, 0.25);
    }
  }
  @keyframes wave-fade {
    from {
      opacity: 0.3;
    }
    to {
      opacity: 1;
    }
  }
</style>
