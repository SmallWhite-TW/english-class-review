---
import type { LessonGroup } from '../../lib/content/group-by-lesson.js';

interface Props {
  lesson: LessonGroup;
}

const { lesson } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
const href = `${base}lessons/${lesson.lessonId}/`;
const title = lesson.reviews[0]?.data.title ?? lesson.preStudy[0]?.data.title ?? lesson.lessonId;
const lessonNoStr = String(lesson.lessonNo).padStart(3, '0');
---

<li class="lesson-card" data-lesson-id={lesson.lessonId}>
  <a href={href}>
    <span class="lesson-card__corner lesson-card__corner--tl"></span>
    <span class="lesson-card__corner lesson-card__corner--tr"></span>
    <span class="lesson-card__corner lesson-card__corner--bl"></span>
    <span class="lesson-card__corner lesson-card__corner--br"></span>

    <div class="lesson-card__header">
      <span class="lesson-no">LESSON <span class="lesson-no__num">{lessonNoStr}</span></span>
      <span class="badges">
        {lesson.preStudy.length > 0 && <span class="badge badge--pre">PRE ×{lesson.preStudy.length}</span>}
        {lesson.reviews.length > 0 && <span class="badge badge--review">REV ×{lesson.reviews.length}</span>}
      </span>
    </div>
    <h3>{title}</h3>
    <div class="progress" data-lesson-id={lesson.lessonId}>
      <div class="progress-bar">
        <div class="progress-fill" style="width: 0%"></div>
      </div>
      <span class="progress-label">0%</span>
    </div>
  </a>
</li>

<style>
  .lesson-card {
    position: relative;
    background: linear-gradient(145deg, rgba(17, 22, 34, 0.85) 0%, rgba(11, 13, 21, 0.95) 100%);
    border: 1px solid var(--border);
    transition:
      border-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
    clip-path: polygon(
      12px 0,
      100% 0,
      100% calc(100% - 12px),
      calc(100% - 12px) 100%,
      0 100%,
      0 12px
    );
  }
  .lesson-card:hover {
    border-color: var(--neon-cyan);
    transform: translateY(-3px);
    box-shadow:
      0 0 18px rgba(0, 255, 245, 0.25),
      0 0 40px rgba(255, 0, 170, 0.08);
  }
  .lesson-card a {
    display: block;
    padding: 1rem 1.1rem 1.1rem;
    color: inherit;
    text-decoration: none;
    position: relative;
  }
  .lesson-card__corner {
    position: absolute;
    width: 10px;
    height: 10px;
    border-color: var(--neon-cyan);
    opacity: 0.85;
    transition: opacity 0.2s ease, border-color 0.2s ease;
  }
  .lesson-card__corner--tl {
    top: 0;
    left: 0;
    border-left: 2px solid;
    border-top: 2px solid;
  }
  .lesson-card__corner--tr {
    top: 0;
    right: 0;
    border-right: 2px solid;
    border-top: 2px solid;
  }
  .lesson-card__corner--bl {
    bottom: 0;
    left: 0;
    border-left: 2px solid;
    border-bottom: 2px solid;
  }
  .lesson-card__corner--br {
    bottom: 0;
    right: 0;
    border-right: 2px solid;
    border-bottom: 2px solid;
  }
  .lesson-card:hover .lesson-card__corner {
    border-color: var(--neon-magenta);
    opacity: 1;
  }

  .lesson-card__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .lesson-no {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
  }
  .lesson-no__num {
    color: var(--neon-cyan);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    text-shadow: 0 0 6px rgba(0, 255, 245, 0.4);
  }
  .badges {
    display: flex;
    gap: 0.25rem;
  }
  .badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.5rem;
    border: 1px solid currentColor;
    background: transparent;
    text-transform: uppercase;
  }
  .badge--pre {
    color: var(--neon-yellow);
    box-shadow: inset 0 0 6px rgba(255, 250, 107, 0.1);
  }
  .badge--review {
    color: var(--neon-cyan);
    box-shadow: inset 0 0 6px rgba(0, 255, 245, 0.1);
  }
  h3 {
    margin: 0.65rem 0 0.85rem;
    font-size: 0.95rem;
    line-height: 1.45;
    font-family: var(--font-ui);
    font-weight: 500;
    letter-spacing: 0;
    color: var(--fg);
  }
  .progress {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--muted);
    font-family: var(--font-mono);
  }
  .progress-bar {
    flex: 1;
    height: 4px;
    background: rgba(29, 34, 50, 0.8);
    overflow: hidden;
    position: relative;
  }
  .progress-bar::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      90deg,
      transparent 0,
      transparent 4px,
      rgba(0, 255, 245, 0.08) 4px,
      rgba(0, 255, 245, 0.08) 5px
    );
    pointer-events: none;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--neon-cyan), var(--neon-magenta));
    box-shadow: 0 0 8px rgba(0, 255, 245, 0.65);
    transition: width 0.3s ease;
  }
  .progress-label {
    min-width: 3.5rem;
    text-align: right;
    color: var(--neon-cyan);
    text-shadow: 0 0 6px rgba(0, 255, 245, 0.3);
  }
</style>
