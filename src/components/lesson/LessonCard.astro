---
import type { LessonGroup } from '../../lib/content/group-by-lesson.js';

interface Props {
  lesson: LessonGroup;
}

const { lesson } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
const href = `${base}lessons/${lesson.lessonId}/`;
const title = lesson.reviews[0]?.data.title ?? lesson.preStudy[0]?.data.title ?? lesson.lessonId;
---

<li class="lesson-card">
  <a href={href}>
    <div class="lesson-card__header">
      <span class="lesson-no">Lesson {String(lesson.lessonNo).padStart(3, '0')}</span>
      <span class="badges">
        {lesson.preStudy.length > 0 && <span class="badge badge--pre">預習 ×{lesson.preStudy.length}</span>}
        {lesson.reviews.length > 0 && <span class="badge badge--review">複習 ×{lesson.reviews.length}</span>}
      </span>
    </div>
    <h3>{title}</h3>
    <div class="progress" data-lesson-id={lesson.lessonId}>
      <div class="progress-bar">
        <div class="progress-fill" style="width: 0%"></div>
      </div>
      <span class="progress-label">進度 0%</span>
    </div>
  </a>
</li>

<style>
  .lesson-card {
    border: 1px solid #23262c;
    border-radius: 8px;
    background: #151821;
    transition:
      border-color 0.15s ease,
      transform 0.15s ease;
  }
  .lesson-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .lesson-card a {
    display: block;
    padding: 1rem;
    color: inherit;
    text-decoration: none;
  }
  .lesson-card__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .lesson-no {
    color: var(--muted);
    font-size: 0.875rem;
    font-variant-numeric: tabular-nums;
  }
  .badges {
    display: flex;
    gap: 0.25rem;
  }
  .badge {
    font-size: 0.75rem;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    background: #1e2130;
  }
  .badge--pre {
    color: #ffcc66;
  }
  .badge--review {
    color: #88d4ff;
  }
  h3 {
    margin: 0.5rem 0 1rem;
    font-size: 1rem;
    line-height: 1.4;
  }
  .progress {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--muted);
  }
  .progress-bar {
    flex: 1;
    height: 6px;
    background: #23262c;
    border-radius: 3px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: var(--accent);
    transition: width 0.2s ease;
  }
  .progress-label {
    min-width: 4.5rem;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
</style>
