---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const baseUrl = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <header>
      <nav>
        <a href={baseUrl}>English Class Review</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <small>White &amp; Dave · English Class Review</small>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0f1115;
    --fg: #e6e6e6;
    --accent: #4ea1ff;
    --muted: #8a8f98;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      "Segoe UI",
      Roboto,
      "Noto Sans TC",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--fg);
    min-height: 100dvh;
  }

  body {
    display: flex;
    flex-direction: column;
  }

  header,
  footer {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #23262c;
  }

  footer {
    border-bottom: none;
    border-top: 1px solid #23262c;
    color: var(--muted);
    margin-top: auto;
  }

  main {
    flex: 1;
    padding: 1.5rem;
    max-width: 960px;
    width: 100%;
    margin: 0 auto;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }
</style>
