---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SpeakButton from '../../components/speech/SpeakButton.astro';
import type { ReviewItem } from '../../types/content.js';
import itemsData from '../../content/generated/items.json';

const items = itemsData as ReviewItem[];
const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;

const byLesson = new Map<string, ReviewItem[]>();
for (const entry of items) {
  const list = byLesson.get(entry.lessonId) ?? [];
  list.push(entry);
  byLesson.set(entry.lessonId, list);
}
const lessonIds = Array.from(byLesson.keys()).sort();

const typeCounts = {
  vocabulary: items.filter((i) => i.type === 'vocabulary').length,
  phrase: items.filter((i) => i.type === 'phrase').length,
  sentence: items.filter((i) => i.type === 'sentence').length,
  natural: items.filter((i) => i.type === 'natural').length,
};

// Trim payload for the client: only keep fields the page needs.
const clientItems = items.map((it) => ({
  id: it.id,
  type: it.type,
  english: it.english,
  meaningZh: it.meaningZh,
  lessonId: it.lessonId,
  reviewSlug: it.reviewSlug,
  topicIndex: it.topicIndex,
  topicTitle: it.topicTitle,
  section: it.section,
}));
---

<BaseLayout title="Item Index" description={`共 ${items.length} 項可複習內容`}>
  <nav class="breadcrumb"><a href={base}>← 首頁</a></nav>

  <h1 class="glitch" data-text="ITEM INDEX">ITEM INDEX</h1>
  <p class="meta">
    共 <strong>{items.length}</strong> 項 · 涵蓋 {lessonIds.length} 堂課
    <span class="meta-divider">·</span>
    <span class="meta-pill meta-pill--vocab">{typeCounts.vocabulary} words</span>
    <span class="meta-pill meta-pill--phrase">{typeCounts.phrase} phrases</span>
    <span class="meta-pill meta-pill--sentence">{typeCounts.sentence} sentences</span>
    <span class="meta-pill meta-pill--natural">{typeCounts.natural} natural</span>
  </p>

  <div class="view-tabs" role="tablist">
    <button type="button" class="view-tab is-active" data-view="list" role="tab" aria-selected="true">
      LIST
    </button>
    <button type="button" class="view-tab" data-view="flashcard" role="tab" aria-selected="false">
      FLASHCARD
    </button>
    <a href={`${base}review-session/`} class="view-tab view-tab--link">
      → SESSION
    </a>
  </div>

  <div class="controls">
    <input
      type="search"
      id="vocab-search"
      placeholder=">>> 搜尋英文、中文或片語…"
      autocomplete="off"
    />
    <select id="vocab-lesson-filter">
      <option value="">所有 Lesson</option>
      {lessonIds.map((id) => <option value={id}>{id}</option>)}
    </select>
    <select id="vocab-type-filter">
      <option value="">所有類型</option>
      <option value="vocabulary">單字 Vocabulary</option>
      <option value="phrase">片語 Phrase</option>
      <option value="sentence">例句 Sentence</option>
      <option value="natural">更自然的說法 Natural</option>
    </select>
  </div>

  <p class="result-count"><span id="result-count">{items.length}</span> 項</p>

  <!-- LIST VIEW -->
  <section id="list-view" class="view is-active">
    <ul id="vocab-list" class="vocab-list">
      {items.map((entry) => (
        <li
          class:list={['vocab-item', `vocab-item--${entry.type}`]}
          data-english={entry.english.toLowerCase()}
          data-meaning={(entry.meaningZh ?? '').toLowerCase()}
          data-lesson-id={entry.lessonId}
          data-type={entry.type}
        >
          <div class="vocab-main">
            <SpeakButton text={entry.english} lang="en-US" />
            <span class="item-type-tag">{entry.type.slice(0, 4).toUpperCase()}</span>
            <code class="term">{entry.english}</code>
            {entry.meaningZh && <span class="meaning">{entry.meaningZh}</span>}
          </div>
          <div class="vocab-meta">
            <a href={`${base}review/${entry.reviewSlug}/`}>{entry.lessonId}</a>
            {entry.topicTitle && <span class="topic">{entry.topicTitle}</span>}
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- FLASHCARD VIEW -->
  <section id="flashcard-view" class="view flashcard-view">
    <div class="flashcard-stage">
      <div class="flashcard-meta">
        <span class="fc-tag">>> 字卡只顯示老師講的單字 + 片語</span>
        <span class="flashcard-count"><span id="fc-index">0</span> / <span id="fc-total">0</span></span>
      </div>
      <div class="flashcard" id="flashcard" role="button" tabindex="0" aria-label="點擊或按空白鍵翻卡">
        <div class="flashcard-face flashcard-front">
          <span class="fc-type-badge" id="fc-front-type">—</span>
          <div class="flashcard-term" id="fc-term">—</div>
          <div class="flashcard-hint">點卡片 / Space 翻面</div>
        </div>
        <div class="flashcard-face flashcard-back">
          <span class="fc-type-badge" id="fc-back-type">—</span>
          <div class="flashcard-english-sm" id="fc-english-sm">—</div>
          <div class="flashcard-meaning" id="fc-meaning">—</div>
          <div class="flashcard-topic" id="fc-topic"></div>
        </div>
      </div>

      <!-- Examples panel: appears below the card after flip, collapsible -->
      <details class="examples-panel" id="examples-panel">
        <summary class="examples-summary">
          <span class="examples-summary-text">▽ 展開使用例子</span>
          <span class="examples-summary-count" id="examples-count">—</span>
        </summary>
        <ul class="examples-list" id="examples-list"></ul>
        <p class="examples-empty" id="examples-empty" hidden>
          這個 topic 沒有對應的例句／更自然說法。
        </p>
      </details>

      <div class="flashcard-controls">
        <button type="button" class="fc-btn fc-btn--prev" id="fc-prev" aria-label="上一張">◀ PREV</button>
        <button type="button" class="fc-btn fc-btn--speak" id="fc-speak" aria-label="發音">🔊 SPEAK</button>
        <button type="button" class="fc-btn fc-btn--flip" id="fc-flip" aria-label="翻面">⟲ FLIP</button>
        <button type="button" class="fc-btn fc-btn--next" id="fc-next" aria-label="下一張">NEXT ▶</button>
      </div>

      <div class="flashcard-shortcuts">
        <kbd>Space</kbd> 翻面 · <kbd>←</kbd> 上一張 · <kbd>→</kbd> 下一張 · <kbd>P</kbd> 發音 · <kbd>S</kbd> 洗牌 · <kbd>E</kbd> 展開例子
      </div>

      <div class="flashcard-empty" id="fc-empty" hidden>
        <p>目前篩選結果沒有可用的字卡（lesson 範圍可能太小）。調整左上 LESSON 過濾器試試。</p>
      </div>
    </div>
  </section>

  <script
    is:inline
    id="items-data"
    type="application/json"
    set:html={JSON.stringify(clientItems)}
  />
</BaseLayout>

<script>
  import { wireSpeakButtons, speak, stop } from '../../lib/speech/speak-ui';
  import type { ReviewItem } from '../../types/content';

  type ClientItem = Pick<
    ReviewItem,
    'id' | 'type' | 'english' | 'meaningZh' | 'lessonId' | 'reviewSlug' | 'topicIndex' | 'topicTitle' | 'section'
  >;

  const dataEl = document.getElementById('items-data');
  const allItems: ClientItem[] = dataEl?.textContent ? JSON.parse(dataEl.textContent) : [];

  // Group sentence + natural by `${lessonId}::${topicIndex ?? 'no-topic'}`
  // so each vocab/phrase card can pull "examples" of how it might appear.
  const examplesByTopic = new Map<string, ClientItem[]>();
  for (const it of allItems) {
    if (it.type !== 'sentence' && it.type !== 'natural') continue;
    const key = `${it.lessonId}::${it.topicIndex ?? 'no-topic'}`;
    const list = examplesByTopic.get(key) ?? [];
    list.push(it);
    examplesByTopic.set(key, list);
  }
  function lookupExamples(item: ClientItem): ClientItem[] {
    const key = `${item.lessonId}::${item.topicIndex ?? 'no-topic'}`;
    const all = examplesByTopic.get(key) ?? [];
    // Prefer examples that actually contain the term (case-insensitive match).
    const lower = item.english.toLowerCase();
    const containing = all.filter((e) => e.english.toLowerCase().includes(lower));
    if (containing.length > 0) return containing.slice(0, 8);
    return all.slice(0, 8);
  }

  const TYPE_LABEL: Record<ClientItem['type'], string> = {
    vocabulary: 'WORD',
    phrase: 'PHRASE',
    sentence: 'SENTENCE',
    natural: 'NATURAL',
  };

  const search = document.getElementById('vocab-search') as HTMLInputElement | null;
  const lessonFilter = document.getElementById('vocab-lesson-filter') as HTMLSelectElement | null;
  const typeFilter = document.getElementById('vocab-type-filter') as HTMLSelectElement | null;
  const listRoot = document.getElementById('vocab-list');
  const countEl = document.getElementById('result-count');

  function applyListFilters(): void {
    if (!listRoot) return;
    const q = (search?.value ?? '').trim().toLowerCase();
    const lesson = lessonFilter?.value ?? '';
    const type = typeFilter?.value ?? '';
    let visible = 0;
    listRoot.querySelectorAll<HTMLElement>('.vocab-item').forEach((item) => {
      const english = item.dataset.english ?? '';
      const meaning = item.dataset.meaning ?? '';
      const matchesQ = q === '' || english.includes(q) || meaning.includes(q);
      const matchesLesson = lesson === '' || item.dataset.lessonId === lesson;
      const matchesType = type === '' || item.dataset.type === type;
      const show = matchesQ && matchesLesson && matchesType;
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (countEl) countEl.textContent = String(visible);
  }

  // -------- Flashcard --------
  let currentView: 'list' | 'flashcard' = 'list';
  let deck: ClientItem[] = [];
  let index = 0;
  let flipped = false;

  const flashcardEl = document.getElementById('flashcard');
  const termEl = document.getElementById('fc-term');
  const englishSmEl = document.getElementById('fc-english-sm');
  const meaningEl = document.getElementById('fc-meaning');
  const topicEl = document.getElementById('fc-topic');
  const idxEl = document.getElementById('fc-index');
  const totalEl = document.getElementById('fc-total');
  const emptyEl = document.getElementById('fc-empty');
  const frontTypeEl = document.getElementById('fc-front-type');
  const backTypeEl = document.getElementById('fc-back-type');

  const examplesPanel = document.getElementById('examples-panel') as HTMLDetailsElement | null;
  const examplesList = document.getElementById('examples-list');
  const examplesCount = document.getElementById('examples-count');
  const examplesEmpty = document.getElementById('examples-empty');

  function buildFlashcardDeck(): ClientItem[] {
    const q = (search?.value ?? '').trim().toLowerCase();
    const lesson = lessonFilter?.value ?? '';
    return allItems.filter((entry) => {
      // Hard rule: flashcard mode = vocab + phrase only.
      if (entry.type !== 'vocabulary' && entry.type !== 'phrase') return false;
      const matchesQ =
        q === '' ||
        entry.english.toLowerCase().includes(q) ||
        (entry.meaningZh ?? '').toLowerCase().includes(q);
      const matchesLesson = lesson === '' || entry.lessonId === lesson;
      return matchesQ && matchesLesson;
    });
  }

  function renderExamplesFor(item: ClientItem): void {
    if (!examplesList || !examplesCount || !examplesEmpty || !examplesPanel) return;
    const examples = lookupExamples(item);
    examplesList.innerHTML = '';
    if (examples.length === 0) {
      examplesEmpty.removeAttribute('hidden');
      examplesCount.textContent = '0 例';
      return;
    }
    examplesEmpty.setAttribute('hidden', 'true');
    examplesCount.textContent = `${examples.length} 例`;

    for (const ex of examples) {
      const li = document.createElement('li');
      li.className = `example-item example-item--${ex.type}`;

      const speakBtn = document.createElement('button');
      speakBtn.type = 'button';
      speakBtn.className = 'speak-btn speak-btn--inline';
      speakBtn.dataset.speakText = ex.english;
      speakBtn.dataset.speakLang = 'en-US';
      speakBtn.setAttribute('aria-label', `播放：${ex.english}`);
      speakBtn.title = `播放發音：${ex.english}`;
      speakBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>`;

      const tag = document.createElement('span');
      tag.className = 'example-tag';
      tag.textContent = TYPE_LABEL[ex.type];

      const text = document.createElement('span');
      text.className = 'example-text';
      // Highlight the current term within the example
      const termLower = item.english.toLowerCase();
      const fullLower = ex.english.toLowerCase();
      const start = fullLower.indexOf(termLower);
      if (start >= 0) {
        const before = ex.english.slice(0, start);
        const match = ex.english.slice(start, start + item.english.length);
        const after = ex.english.slice(start + item.english.length);
        const beforeNode = document.createTextNode(before);
        const mark = document.createElement('mark');
        mark.textContent = match;
        const afterNode = document.createTextNode(after);
        text.append(beforeNode, mark, afterNode);
      } else {
        text.textContent = ex.english;
      }

      const meaning = document.createElement('span');
      meaning.className = 'example-meaning';
      meaning.textContent = ex.meaningZh ? `— ${ex.meaningZh}` : '';

      li.append(speakBtn, tag, text);
      if (ex.meaningZh) li.append(meaning);
      examplesList.appendChild(li);
    }

    wireSpeakButtons(examplesList);
  }

  function renderCard(): void {
    if (
      !flashcardEl ||
      !termEl ||
      !englishSmEl ||
      !meaningEl ||
      !topicEl ||
      !idxEl ||
      !totalEl ||
      !emptyEl ||
      !frontTypeEl ||
      !backTypeEl ||
      !examplesPanel
    )
      return;

    totalEl.textContent = String(deck.length);
    if (deck.length === 0) {
      flashcardEl.setAttribute('hidden', 'true');
      emptyEl.removeAttribute('hidden');
      examplesPanel.setAttribute('hidden', 'true');
      idxEl.textContent = '0';
      return;
    }

    flashcardEl.removeAttribute('hidden');
    emptyEl.setAttribute('hidden', 'true');
    examplesPanel.removeAttribute('hidden');
    idxEl.textContent = String(index + 1);

    const entry = deck[index];
    if (!entry) return;
    termEl.textContent = entry.english;
    englishSmEl.textContent = entry.english;
    meaningEl.textContent = entry.meaningZh || '（這條沒有中文，靠例句去回想用法）';
    topicEl.textContent = entry.topicTitle
      ? `${entry.lessonId} · Topic ${entry.topicIndex ?? '?'} · ${entry.topicTitle}`
      : entry.lessonId;

    const typeLabel = TYPE_LABEL[entry.type];
    frontTypeEl.textContent = typeLabel;
    frontTypeEl.className = `fc-type-badge fc-type-badge--${entry.type}`;
    backTypeEl.textContent = typeLabel;
    backTypeEl.className = `fc-type-badge fc-type-badge--${entry.type}`;

    flipped = false;
    flashcardEl.classList.remove('is-flipped');
    examplesPanel.open = false; // collapse when moving to a new card
    renderExamplesFor(entry);
  }

  function rebuildDeck(): void {
    deck = buildFlashcardDeck();
    index = 0;
    renderCard();
  }

  function flipCard(): void {
    if (!flashcardEl || deck.length === 0) return;
    flipped = !flipped;
    flashcardEl.classList.toggle('is-flipped', flipped);
  }

  function nextCard(): void {
    if (deck.length === 0) return;
    index = (index + 1) % deck.length;
    renderCard();
  }

  function prevCard(): void {
    if (deck.length === 0) return;
    index = (index - 1 + deck.length) % deck.length;
    renderCard();
  }

  function speakCurrent(): void {
    if (deck.length === 0) return;
    const entry = deck[index];
    if (!entry) return;
    speak(entry.english, { lang: 'en-US' }).catch(() => {});
  }

  function shuffleDeck(): void {
    for (let i = deck.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [deck[i], deck[j]] = [deck[j] as ClientItem, deck[i] as ClientItem];
    }
    index = 0;
    renderCard();
  }

  function toggleExamples(): void {
    if (!examplesPanel) return;
    examplesPanel.open = !examplesPanel.open;
  }

  document.querySelectorAll<HTMLButtonElement>('.view-tab').forEach((btn) => {
    btn.addEventListener('click', () => {
      const view = btn.dataset.view as 'list' | 'flashcard' | undefined;
      if (!view) return;
      currentView = view;
      document.querySelectorAll<HTMLButtonElement>('.view-tab').forEach((b) => {
        if (!b.dataset.view) return;
        const active = b.dataset.view === view;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-selected', String(active));
      });
      document.querySelectorAll<HTMLElement>('.view').forEach((v) => {
        v.classList.toggle('is-active', v.id === `${view}-view`);
      });
      if (view === 'flashcard') rebuildDeck();
    });
  });

  flashcardEl?.addEventListener('click', flipCard);
  flashcardEl?.addEventListener('keydown', (ev) => {
    if ((ev as KeyboardEvent).key === 'Enter') flipCard();
  });
  document.getElementById('fc-flip')?.addEventListener('click', (ev) => {
    ev.stopPropagation();
    flipCard();
  });
  document.getElementById('fc-prev')?.addEventListener('click', (ev) => {
    ev.stopPropagation();
    prevCard();
  });
  document.getElementById('fc-next')?.addEventListener('click', (ev) => {
    ev.stopPropagation();
    nextCard();
  });
  document.getElementById('fc-speak')?.addEventListener('click', (ev) => {
    ev.stopPropagation();
    speakCurrent();
  });

  // Don't let clicks inside the examples panel bubble up and flip the card
  examplesPanel?.addEventListener('click', (ev) => ev.stopPropagation());

  document.addEventListener('keydown', (ev) => {
    if (currentView !== 'flashcard') return;
    const tag = (ev.target as HTMLElement | null)?.tagName;
    if (tag === 'INPUT' || tag === 'SELECT' || tag === 'TEXTAREA') return;
    switch (ev.key) {
      case ' ':
        ev.preventDefault();
        flipCard();
        break;
      case 'ArrowRight':
        nextCard();
        break;
      case 'ArrowLeft':
        prevCard();
        break;
      case 'p':
      case 'P':
        speakCurrent();
        break;
      case 's':
      case 'S':
        shuffleDeck();
        break;
      case 'e':
      case 'E':
        toggleExamples();
        break;
    }
  });

  [search, lessonFilter, typeFilter].forEach((el) => {
    el?.addEventListener('input', () => {
      applyListFilters();
      if (currentView === 'flashcard') rebuildDeck();
    });
    el?.addEventListener('change', () => {
      applyListFilters();
      if (currentView === 'flashcard') rebuildDeck();
    });
  });

  wireSpeakButtons();
  applyListFilters();

  window.addEventListener('beforeunload', () => stop());
</script>

<style>
  .breadcrumb {
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }
  h1 {
    font-family: var(--font-display);
    letter-spacing: 0.1em;
    font-size: 2.25rem;
  }
  .meta {
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }
  .meta strong {
    color: var(--neon-cyan);
  }
  .meta-divider {
    margin: 0 0.25rem;
  }
  .meta-pill {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.1rem 0.5rem;
    border: 1px solid currentColor;
    letter-spacing: 0.05em;
  }
  .meta-pill--vocab { color: var(--neon-yellow); }
  .meta-pill--phrase { color: var(--neon-cyan); }
  .meta-pill--sentence { color: var(--neon-magenta); }
  .meta-pill--natural { color: var(--neon-purple); }

  .view-tabs {
    display: flex;
    gap: 0.5rem;
    margin: 1.5rem 0 0.75rem;
  }
  .view-tab {
    position: relative;
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--neon-cyan);
    padding: 0.5rem 1.25rem;
    font-family: var(--font-mono);
    font-weight: 600;
    letter-spacing: 0.1em;
    cursor: pointer;
    text-decoration: none;
    clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    transition: all 0.15s ease;
  }
  .view-tab:hover {
    color: var(--neon-cyan);
    box-shadow: 0 0 8px rgba(0, 255, 245, 0.4);
  }
  .view-tab.is-active {
    color: var(--neon-cyan);
    background: rgba(0, 255, 245, 0.12);
    box-shadow: 0 0 12px rgba(0, 255, 245, 0.6);
  }
  .view-tab--link {
    border-color: var(--neon-magenta);
    color: var(--neon-magenta);
  }
  .view-tab--link:hover {
    box-shadow: 0 0 8px rgba(255, 0, 170, 0.5);
  }

  .controls {
    display: flex;
    gap: 0.5rem;
    margin: 0.5rem 0 1rem;
    flex-wrap: wrap;
  }
  .controls input,
  .controls select {
    background: #0b0d15;
    color: var(--fg);
    border: 1px solid var(--neon-cyan);
    border-radius: 0;
    padding: 0.55rem 0.85rem;
    font-family: inherit;
    box-shadow: inset 0 0 8px rgba(0, 255, 245, 0.06);
  }
  .controls input {
    flex: 1;
    min-width: 200px;
  }
  .controls input:focus,
  .controls select:focus {
    outline: none;
    border-color: var(--neon-magenta);
    box-shadow: 0 0 10px rgba(255, 0, 170, 0.5), inset 0 0 8px rgba(255, 0, 170, 0.1);
  }
  .result-count {
    color: var(--muted);
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }
  .result-count #result-count {
    color: var(--neon-cyan);
  }

  .view {
    display: none;
  }
  .view.is-active {
    display: block;
  }
  .vocab-list {
    list-style: none;
    padding: 0;
  }
  .vocab-item {
    padding: 0.75rem 1rem;
    background: rgba(21, 24, 33, 0.7);
    border: 1px solid #23262c;
    border-left: 2px solid var(--neon-cyan);
    margin-bottom: 0.5rem;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }
  .vocab-item--vocabulary { border-left-color: var(--neon-yellow); }
  .vocab-item--phrase { border-left-color: var(--neon-cyan); }
  .vocab-item--sentence { border-left-color: var(--neon-magenta); }
  .vocab-item--natural { border-left-color: var(--neon-purple); }
  .vocab-item:hover {
    box-shadow: 0 0 10px rgba(0, 255, 245, 0.25);
    background: rgba(0, 255, 245, 0.03);
  }
  .vocab-main {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
