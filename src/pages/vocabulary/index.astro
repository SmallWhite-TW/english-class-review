---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SpeakButton from '../../components/speech/SpeakButton.astro';
import type { VocabularyEntry } from '../../types/content.js';
import vocabularyData from '../../content/generated/vocabulary.json';

const vocabulary = vocabularyData as VocabularyEntry[];
const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;

const byLesson = new Map<string, VocabularyEntry[]>();
for (const entry of vocabulary) {
  const list = byLesson.get(entry.lessonId) ?? [];
  list.push(entry);
  byLesson.set(entry.lessonId, list);
}
const lessonIds = Array.from(byLesson.keys()).sort();
---

<BaseLayout title="單字索引" description={`共 ${vocabulary.length} 條單字／片語`}>
  <nav class="breadcrumb"><a href={base}>← 首頁</a></nav>

  <h1 class="glitch" data-text="VOCABULARY">VOCABULARY</h1>
  <p class="meta">共 <strong>{vocabulary.length}</strong> 條 · 涵蓋 {lessonIds.length} 堂課</p>

  <div class="view-tabs" role="tablist">
    <button type="button" class="view-tab is-active" data-view="list" role="tab" aria-selected="true">
      <span class="corner"></span>LIST
    </button>
    <button type="button" class="view-tab" data-view="flashcard" role="tab" aria-selected="false">
      <span class="corner"></span>FLASHCARD
    </button>
  </div>

  <div class="controls">
    <input
      type="search"
      id="vocab-search"
      placeholder=">>> 搜尋英文、中文或片語…"
      autocomplete="off"
    />
    <select id="vocab-lesson-filter">
      <option value="">所有 Lesson</option>
      {lessonIds.map((id) => <option value={id}>{id}</option>)}
    </select>
    <select id="vocab-section-filter">
      <option value="">所有類別</option>
      <option value="關鍵單字／片語">關鍵單字／片語</option>
      <option value="更自然的說法">更自然的說法</option>
      <option value="補充例句">補充例句</option>
      <option value="other">其他</option>
    </select>
  </div>

  <p class="result-count"><span id="result-count">{vocabulary.length}</span> 條</p>

  <!-- LIST VIEW -->
  <section id="list-view" class="view is-active">
    <ul id="vocab-list" class="vocab-list">
      {vocabulary.map((entry) => (
        <li
          class="vocab-item"
          data-term={entry.term.toLowerCase()}
          data-meaning={(entry.meaningZh ?? '').toLowerCase()}
          data-lesson-id={entry.lessonId}
          data-section={entry.section}
        >
          <div class="vocab-main">
            <SpeakButton text={entry.term} lang="en-US" />
            <code class="term">{entry.term}</code>
            {entry.meaningZh && <span class="meaning">{entry.meaningZh}</span>}
          </div>
          <div class="vocab-meta">
            <a href={`${base}review/${entry.reviewSlug}/`}>{entry.lessonId}</a>
            {entry.topicTitle && <span class="topic">{entry.topicTitle}</span>}
            <span class="section">{entry.section}</span>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- FLASHCARD VIEW -->
  <section id="flashcard-view" class="view flashcard-view">
    <div class="flashcard-stage">
      <div class="flashcard-count"><span id="fc-index">0</span> / <span id="fc-total">0</span></div>
      <div class="flashcard" id="flashcard" role="button" tabindex="0" aria-label="點擊或按空白鍵翻卡">
        <div class="flashcard-face flashcard-front">
          <div class="flashcard-term" id="fc-term">—</div>
          <div class="flashcard-hint">點擊卡片 / 空白鍵 翻面</div>
        </div>
        <div class="flashcard-face flashcard-back">
          <div class="flashcard-meaning" id="fc-meaning">—</div>
          <div class="flashcard-topic" id="fc-topic"></div>
        </div>
      </div>

      <div class="flashcard-controls">
        <button type="button" class="fc-btn fc-btn--prev" id="fc-prev" aria-label="上一張">◀ PREV</button>
        <button type="button" class="fc-btn fc-btn--speak" id="fc-speak" aria-label="發音">🔊 SPEAK</button>
        <button type="button" class="fc-btn fc-btn--flip" id="fc-flip" aria-label="翻面">⟲ FLIP</button>
        <button type="button" class="fc-btn fc-btn--next" id="fc-next" aria-label="下一張">NEXT ▶</button>
      </div>

      <div class="flashcard-shortcuts">
        <kbd>Space</kbd> 翻面 · <kbd>←</kbd> 上一張 · <kbd>→</kbd> 下一張 · <kbd>P</kbd> 發音 · <kbd>S</kbd> 洗牌
      </div>

      <div class="flashcard-empty" id="fc-empty" hidden>
        <p>目前篩選結果沒有可用的卡片。調整上方篩選條件試試。</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { wireSpeakButtons, speak, stop } from '../../lib/speech/speak-ui';
  import type { VocabularyEntry } from '../../types/content';

  const search = document.getElementById('vocab-search') as HTMLInputElement | null;
  const lessonFilter = document.getElementById('vocab-lesson-filter') as HTMLSelectElement | null;
  const sectionFilter = document.getElementById('vocab-section-filter') as HTMLSelectElement | null;
  const listRoot = document.getElementById('vocab-list');
  const countEl = document.getElementById('result-count');

  // Collect full dataset from DOM once (data is already server-rendered).
  const allEntries: (VocabularyEntry & { el: HTMLElement })[] = [];
  listRoot?.querySelectorAll<HTMLElement>('.vocab-item').forEach((el) => {
    const term = el.querySelector<HTMLElement>('.term')?.textContent ?? '';
    const meaning = el.querySelector<HTMLElement>('.meaning')?.textContent ?? '';
    const topic = el.querySelector<HTMLElement>('.topic')?.textContent ?? '';
    const lessonId = el.dataset.lessonId ?? '';
    const section = (el.dataset.section ?? 'other') as VocabularyEntry['section'];
    allEntries.push({
      el,
      id: `${lessonId}-${term}`,
      term,
      meaningZh: meaning,
      lessonId,
      lessonNo: 0,
      reviewSlug: '',
      topicTitle: topic || undefined,
      section,
    });
  });

  function filteredEntries(): (VocabularyEntry & { el: HTMLElement })[] {
    const q = (search?.value ?? '').trim().toLowerCase();
    const lesson = lessonFilter?.value ?? '';
    const section = sectionFilter?.value ?? '';
    return allEntries.filter((entry) => {
      const matchesQ =
        q === '' ||
        entry.term.toLowerCase().includes(q) ||
        (entry.meaningZh ?? '').toLowerCase().includes(q);
      const matchesLesson = lesson === '' || entry.lessonId === lesson;
      const matchesSection = section === '' || entry.section === section;
      return matchesQ && matchesLesson && matchesSection;
    });
  }

  function applyListFilters(): void {
    if (!listRoot) return;
    const q = (search?.value ?? '').trim().toLowerCase();
    const lesson = lessonFilter?.value ?? '';
    const section = sectionFilter?.value ?? '';
    let visible = 0;
    listRoot.querySelectorAll<HTMLElement>('.vocab-item').forEach((item) => {
      const term = item.dataset.term ?? '';
      const meaning = item.dataset.meaning ?? '';
      const matchesQ = q === '' || term.includes(q) || meaning.includes(q);
      const matchesLesson = lesson === '' || item.dataset.lessonId === lesson;
      const matchesSection = section === '' || item.dataset.section === section;
      const show = matchesQ && matchesLesson && matchesSection;
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (countEl) countEl.textContent = String(visible);
  }

  // -------- Flashcard state --------
  let currentView: 'list' | 'flashcard' = 'list';
  let deck: (VocabularyEntry & { el: HTMLElement })[] = [];
  let index = 0;
  let flipped = false;

  const flashcardEl = document.getElementById('flashcard');
  const termEl = document.getElementById('fc-term');
  const meaningEl = document.getElementById('fc-meaning');
  const topicEl = document.getElementById('fc-topic');
  const idxEl = document.getElementById('fc-index');
  const totalEl = document.getElementById('fc-total');
  const emptyEl = document.getElementById('fc-empty');

  function renderCard(): void {
    if (!flashcardEl || !termEl || !meaningEl || !topicEl || !idxEl || !totalEl || !emptyEl)
      return;
    totalEl.textContent = String(deck.length);

    if (deck.length === 0) {
      flashcardEl.setAttribute('hidden', 'true');
      emptyEl.removeAttribute('hidden');
      idxEl.textContent = '0';
      if (countEl) countEl.textContent = '0';
      return;
    }

    flashcardEl.removeAttribute('hidden');
    emptyEl.setAttribute('hidden', 'true');
    idxEl.textContent = String(index + 1);

    const entry = deck[index];
    if (!entry) return;
    termEl.textContent = entry.term;
    meaningEl.textContent = entry.meaningZh || '（無中文翻譯）';
    topicEl.textContent = entry.topicTitle
      ? `${entry.lessonId} · ${entry.topicTitle}`
      : entry.lessonId;

    flipped = false;
    flashcardEl.classList.remove('is-flipped');
  }

  function rebuildDeck(): void {
    deck = filteredEntries();
    index = 0;
    renderCard();
  }

  function flipCard(): void {
    if (!flashcardEl || deck.length === 0) return;
    flipped = !flipped;
    flashcardEl.classList.toggle('is-flipped', flipped);
  }

  function nextCard(): void {
    if (deck.length === 0) return;
    index = (index + 1) % deck.length;
    renderCard();
  }

  function prevCard(): void {
    if (deck.length === 0) return;
    index = (index - 1 + deck.length) % deck.length;
    renderCard();
  }

  function speakCurrent(): void {
    if (deck.length === 0) return;
    const entry = deck[index];
    if (!entry) return;
    speak(entry.term, { lang: 'en-US' }).catch(() => {});
  }

  function shuffleDeck(): void {
    for (let i = deck.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [deck[i], deck[j]] = [deck[j] as typeof deck[number], deck[i] as typeof deck[number]];
    }
    index = 0;
    renderCard();
  }

  // -------- Wire UI --------
  document.querySelectorAll<HTMLButtonElement>('.view-tab').forEach((btn) => {
    btn.addEventListener('click', () => {
      const view = btn.dataset.view as 'list' | 'flashcard' | undefined;
      if (!view) return;
      currentView = view;
      document.querySelectorAll<HTMLButtonElement>('.view-tab').forEach((b) => {
        const active = b.dataset.view === view;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-selected', String(active));
      });
      document.querySelectorAll<HTMLElement>('.view').forEach((v) => {
        v.classList.toggle('is-active', v.id === `${view}-view`);
      });
      if (view === 'flashcard') rebuildDeck();
    });
  });

  flashcardEl?.addEventListener('click', flipCard);
  flashcardEl?.addEventListener('keydown', (ev) => {
    if ((ev as KeyboardEvent).key === 'Enter') flipCard();
  });
  document.getElementById('fc-flip')?.addEventListener('click', (ev) => {
    ev.stopPropagation();
    flipCard();
  });
  document.getElementById('fc-prev')?.addEventListener('click', (ev) => {
    ev.stopPropagation();
    prevCard();
  });
  document.getElementById('fc-next')?.addEventListener('click', (ev) => {
    ev.stopPropagation();
    nextCard();
  });
  document.getElementById('fc-speak')?.addEventListener('click', (ev) => {
    ev.stopPropagation();
    speakCurrent();
  });

  document.addEventListener('keydown', (ev) => {
    if (currentView !== 'flashcard') return;
    const tag = (ev.target as HTMLElement | null)?.tagName;
    if (tag === 'INPUT' || tag === 'SELECT' || tag === 'TEXTAREA') return;
    switch (ev.key) {
      case ' ':
        ev.preventDefault();
        flipCard();
        break;
      case 'ArrowRight':
        nextCard();
        break;
      case 'ArrowLeft':
        prevCard();
        break;
      case 'p':
      case 'P':
        speakCurrent();
        break;
      case 's':
      case 'S':
        shuffleDeck();
        break;
    }
  });

  [search, lessonFilter, sectionFilter].forEach((el) => {
    el?.addEventListener('input', () => {
      applyListFilters();
      if (currentView === 'flashcard') rebuildDeck();
    });
    el?.addEventListener('change', () => {
      applyListFilters();
      if (currentView === 'flashcard') rebuildDeck();
    });
  });

  wireSpeakButtons();
  applyListFilters();

  window.addEventListener('beforeunload', () => stop());
</script>

<style>
  .breadcrumb {
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }
  h1 {
    font-family: 'Space Mono', 'JetBrains Mono', ui-monospace, monospace;
    letter-spacing: 0.1em;
    font-size: 2.25rem;
  }
  .meta {
    color: var(--muted);
  }
  .view-tabs {
    display: flex;
    gap: 0.5rem;
    margin: 1.5rem 0 0.75rem;
  }
  .view-tab {
    position: relative;
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--neon-cyan, #00ffff);
    padding: 0.5rem 1.25rem;
    font-family: inherit;
    font-weight: 600;
    letter-spacing: 0.1em;
    cursor: pointer;
    clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    transition: all 0.15s ease;
  }
  .view-tab:hover {
    color: var(--neon-cyan, #00ffff);
    box-shadow: 0 0 8px rgba(0, 255, 255, 0.4);
  }
  .view-tab.is-active {
    color: var(--neon-cyan, #00ffff);
    background: rgba(0, 255, 255, 0.12);
    box-shadow: 0 0 12px rgba(0, 255, 255, 0.6);
  }
  .controls {
    display: flex;
    gap: 0.5rem;
    margin: 0.5rem 0 1rem;
    flex-wrap: wrap;
  }
  .controls input,
  .controls select {
    background: #0b0d15;
    color: var(--fg);
    border: 1px solid var(--neon-cyan, #00ffff);
    border-radius: 0;
    padding: 0.55rem 0.85rem;
    font-family: inherit;
    box-shadow: inset 0 0 8px rgba(0, 255, 255, 0.06);
  }
  .controls input {
    flex: 1;
    min-width: 200px;
  }
  .controls input:focus,
  .controls select:focus {
    outline: none;
    border-color: var(--neon-magenta, #ff00aa);
    box-shadow: 0 0 10px rgba(255, 0, 170, 0.5), inset 0 0 8px rgba(255, 0, 170, 0.1);
  }
  .result-count {
    color: var(--muted);
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }
  .result-count strong {
    color: var(--neon-cyan, #00ffff);
  }
  .view {
    display: none;
  }
  .view.is-active {
    display: block;
  }
  .vocab-list {
    list-style: none;
    padding: 0;
  }
  .vocab-item {
    padding: 0.75rem 1rem;
    background: rgba(21, 24, 33, 0.7);
    border: 1px solid #23262c;
    border-left: 2px solid var(--neon-cyan, #00ffff);
    margin-bottom: 0.5rem;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }
  .vocab-item:hover {
    border-color: var(--neon-cyan, #00ffff);
    box-shadow: 0 0 10px rgba(0, 255, 255, 0.25);
    background: rgba(0, 255, 255, 0.03);
  }
  .vocab-main {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
  }
  .term {
    font-size: 1.05rem;
    background: rgba(0, 255, 255, 0.08);
    padding: 0.15rem 0.55rem;
    border: 1px solid rgba(0, 255, 255, 0.3);
    color: var(--neon-cyan, #00ffff);
    text-shadow: 0 0 8px rgba(0, 255, 255, 0.5);
  }
  .meaning {
    color: var(--fg);
  }
  .vocab-meta {
    margin-top: 0.3rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-size: 0.75rem;
    color: var(--muted);
  }
  .vocab-meta a {
    color: var(--muted);
  }
  .vocab-meta a:hover {
    color: var(--neon-cyan, #00ffff);
  }
  .topic::before,
  .section::before {
    content: '· ';
  }

  /* ---------------- Flashcard ---------------- */
  .flashcard-view {
    min-height: 400px;
  }
  .flashcard-stage {
    max-width: 560px;
    margin: 1.5rem auto 0;
    text-align: center;
  }
  .flashcard-count {
    font-family: 'Space Mono', ui-monospace, monospace;
    color: var(--muted);
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
    letter-spacing: 0.1em;
  }
  .flashcard-count span {
    color: var(--neon-cyan, #00ffff);
  }
  .flashcard {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    perspective: 1200px;
    cursor: pointer;
    user-select: none;
  }
  .flashcard-face {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: linear-gradient(135deg, #0b0d15 0%, #151a28 100%);
    border: 1px solid var(--neon-cyan, #00ffff);
    box-shadow:
      0 0 24px rgba(0, 255, 255, 0.25),
      inset 0 0 30px rgba(0, 255, 255, 0.05);
    backface-visibility: hidden;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    clip-path: polygon(
      16px 0,
      100% 0,
      100% calc(100% - 16px),
      calc(100% - 16px) 100%,
      0 100%,
      0 16px
    );
  }
  .flashcard-back {
    transform: rotateY(180deg);
    border-color: var(--neon-magenta, #ff00aa);
    box-shadow:
      0 0 24px rgba(255, 0, 170, 0.3),
      inset 0 0 30px rgba(255, 0, 170, 0.06);
  }
  .flashcard.is-flipped .flashcard-front {
    transform: rotateY(-180deg);
  }
  .flashcard.is-flipped .flashcard-back {
    transform: rotateY(0deg);
  }
  .flashcard-term {
    font-size: clamp(1.5rem, 5vw, 2.5rem);
    font-weight: 600;
    color: var(--neon-cyan, #00ffff);
    text-shadow:
      0 0 10px rgba(0, 255, 255, 0.7),
      0 0 20px rgba(0, 255, 255, 0.3);
    letter-spacing: 0.02em;
    word-break: break-word;
  }
  .flashcard-meaning {
    font-size: clamp(1.25rem, 4vw, 1.75rem);
    color: var(--fg);
    text-shadow: 0 0 8px rgba(255, 0, 170, 0.4);
  }
  .flashcard-topic {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.05em;
  }
  .flashcard-hint {
    margin-top: 0.75rem;
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }
  .flashcard-controls {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .fc-btn {
    font-family: 'Space Mono', ui-monospace, monospace;
    font-weight: 600;
    letter-spacing: 0.1em;
    background: transparent;
    color: var(--neon-cyan, #00ffff);
    border: 1px solid var(--neon-cyan, #00ffff);
    padding: 0.5rem 1rem;
    cursor: pointer;
    clip-path: polygon(6px 0, 100% 0, calc(100% - 6px) 100%, 0 100%);
    transition: all 0.15s ease;
  }
  .fc-btn:hover {
    background: rgba(0, 255, 255, 0.1);
    box-shadow: 0 0 10px rgba(0, 255, 255, 0.5);
  }
  .fc-btn--speak {
    color: var(--neon-magenta, #ff00aa);
    border-color: var(--neon-magenta, #ff00aa);
  }
  .fc-btn--speak:hover {
    background: rgba(255, 0, 170, 0.12);
    box-shadow: 0 0 10px rgba(255, 0, 170, 0.6);
  }
  .flashcard-shortcuts {
    margin-top: 1rem;
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.03em;
  }
  .flashcard-shortcuts kbd {
    background: #0b0d15;
    border: 1px solid #23262c;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    color: var(--neon-cyan, #00ffff);
    font-family: inherit;
  }
  .flashcard-empty {
    margin-top: 4rem;
    color: var(--muted);
  }

  /* Glitch heading */
  .glitch {
    position: relative;
    display: inline-block;
    text-shadow: 0 0 10px rgba(0, 255, 255, 0.6);
  }
  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    pointer-events: none;
  }
  .glitch::before {
    color: var(--neon-magenta, #ff00aa);
    animation: glitch-1 3s infinite linear alternate-reverse;
    clip-path: inset(10% 0 70% 0);
    opacity: 0.75;
  }
  .glitch::after {
    color: var(--neon-cyan, #00ffff);
    animation: glitch-2 2.5s infinite linear alternate-reverse;
    clip-path: inset(70% 0 10% 0);
    opacity: 0.75;
  }
  @keyframes glitch-1 {
    0%, 90%, 100% { transform: translate(0); }
    20% { transform: translate(-2px, 1px); }
    40% { transform: translate(-1px, -1px); }
    60% { transform: translate(1px, 2px); }
    80% { transform: translate(2px, -1px); }
  }
  @keyframes glitch-2 {
    0%, 85%, 100% { transform: translate(0); }
    30% { transform: translate(2px, -2px); }
    50% { transform: translate(-2px, 1px); }
    70% { transform: translate(1px, -1px); }
  }
</style>
