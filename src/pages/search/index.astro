---
import BaseLayout from '../../layouts/BaseLayout.astro';
const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
const pagefindBase = `${base}pagefind/`;
---

<BaseLayout title="全文搜尋" description="在所有 lesson 內容中搜尋">
  <nav class="breadcrumb"><a href={base}>← 首頁</a></nav>
  <h1>全文搜尋</h1>
  <p class="meta">搜尋所有 lesson 的內容（預習、複習、topic、單字）。</p>
  <div id="search" />
  <p class="alt">
    只想查單字？ <a href={`${base}vocabulary/`}>前往單字索引</a>
  </p>
</BaseLayout>

<link rel="stylesheet" href={`${pagefindBase}pagefind-ui.css`} />
<script is:inline define:vars={{ pagefindBase, base }}>
  window.addEventListener('DOMContentLoaded', async () => {
    try {
      const mod = await import(/* @vite-ignore */ `${pagefindBase}pagefind-ui.js`);
      const Ctor = mod.PagefindUI ?? mod.default?.PagefindUI ?? mod.default;
      if (!Ctor) throw new Error('PagefindUI constructor not found');
      new Ctor({
        element: '#search',
        showSubResults: true,
        bundlePath: pagefindBase,
        translations: {
          placeholder: '搜尋…',
          clear_search: '清除',
          load_more: '載入更多',
          search_label: '搜尋',
          filters_label: '篩選',
          zero_results: '沒有符合的結果',
          many_results: '共 [SEARCH_TERM] 筆',
          one_result: '找到 [SEARCH_TERM] 筆',
          alt_search: '未找到 [SEARCH_TERM]，改搜 [DIFFERENT_TERM]',
          search_suggestion: '試試 [DIFFERENT_TERM]',
          searching: '搜尋中…',
        },
      });
    } catch (err) {
      const host = document.getElementById('search');
      if (host) {
        host.innerHTML =
          '<p>搜尋索引尚未產生。請在 <code>npm run build</code> 後跑 <code>npx pagefind --site dist</code>，然後重新部署。</p>';
      }
      console.warn('[pagefind]', err);
    }
  });
</script>

<style>
  .breadcrumb {
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }
  .meta {
    color: var(--muted);
  }
  #search {
    margin-top: 1.5rem;
  }
  .alt {
    margin-top: 2rem;
    color: var(--muted);
    font-size: 0.875rem;
  }
</style>
