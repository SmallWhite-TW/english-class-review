# Copy this file to .env and fill in real values. NEVER commit .env.

# ---------- Cloudflare ----------
# Account ID (32-char hex from CF dashboard sidebar, NOT your email)
CF_ACCOUNT_ID=

# API Token with "Edit Cloudflare Workers" scope. Used by wrangler locally and
# by GitHub Actions to deploy the worker.
CF_API_TOKEN=

# KV namespace ID for progress storage.
CF_KV_NAMESPACE_ID=

# Deployed worker URL. Used by Astro build to inject into PUBLIC_WORKER_URL.
CF_WORKER_URL=https://english-class-progress.<account>.workers.dev

# ---------- Profile secrets ----------
# Used by the worker to authenticate each profile's sync requests.
# Generate with: openssl rand -hex 32
# These values end up in the front-end bundle by design — they are not strong
# auth, only a lightweight guard against casual abuse.
WHITE_PROFILE_SECRET=
DAVE_PROFILE_SECRET=

# ---------- Astro build-time injection ----------
# Usually set automatically by CI from CF_WORKER_URL. Only override for local dev.
PUBLIC_WORKER_URL=
